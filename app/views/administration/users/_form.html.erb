<%= form_with model: [ :administration, user ], class: "contents" do |form| %>
  <% if user.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(user.errors.count, "error") %> prohibited this user from being saved:</h2>

      <ul class="list-disc ml-6">
        <% user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :code, class: "block font-medium mb-1" %>
    <%= form.text_field :code, class: "block shadow-sm rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="my-5">
    <%= form.label :first_name, class: "block font-medium mb-1" %>
    <%= form.text_field :first_name, class: "block shadow-sm rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="my-5">
    <%= form.label :last_name, class: "block font-medium mb-1" %>
    <%= form.text_field :last_name, class: "block shadow-sm rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="my-5">
    <%= form.label :email, class: "block font-medium mb-1" %>
    <%= form.email_field :email, class: "block shadow-sm rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
  </div>

  <% if user.new_record? %>
    <div class="my-5">
      <%= form.label :password, class: "block font-medium mb-1" %>
      <%= form.password_field :password, autocomplete: "new-password", class: "block shadow-sm rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :password_confirmation, class: "block font-medium mb-1" %>
      <%= form.password_field :password_confirmation, autocomplete: "new-password", class: "block shadow-sm rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
    </div>
  <% end %>

  <div class="my-5">
    <label class="inline-flex items-center gap-2 font-medium">
      <%= form.check_box :is_admin %>
      Administrator
    </label>
  </div>

  <div class="my-5">
    <label class="inline-flex items-center gap-2 font-medium">
      <%= form.check_box :is_active %>
      Active
    </label>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
