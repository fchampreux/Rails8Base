<% provide(:title, "Edit profile") %>

<div class="flex items-center justify-center min-h-[60vh]">
  <div class="w-full max-w-md bg-white rounded-sm border-2 border-solid border-blue-400 p-8">
    <h2 class="text-xl font-semibold text-emerald-700 mb-6">Edit profile</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-4">
        <%= f.label :code, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :code, autocomplete: "username",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :first_name, autocomplete: "given-name",
              class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
        </div>
        <div>
          <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :last_name, autocomplete: "family-name",
              class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
        </div>
      </div>

      <div class="mb-4">
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="text-xs text-amber-600 mt-1">Awaiting confirmation for: <%= resource.unconfirmed_email %></p>
        <% end %>
      </div>

      <div class="mb-4">
        <%= f.label :password, "New password", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-400 mb-1">Leave blank to keep current password</p>
        <%= f.password_field :password, autocomplete: "new-password",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
        <% if @minimum_password_length %>
          <p class="text-xs text-gray-400 mt-1"><%= @minimum_password_length %> characters minimum</p>
        <% end %>
      </div>

      <div class="mb-4">
        <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
      </div>

      <div class="mb-6">
        <%= f.label :current_password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <p class="text-xs text-gray-400 mb-1">Required to confirm your changes</p>
        <%= f.password_field :current_password, autocomplete: "current-password",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
      </div>

      <div class="mt-6">
        <%= f.submit "Update profile", class: "w-full bg-emerald-700 text-white py-2 px-4 rounded text-sm font-medium hover:bg-emerald-800 cursor-pointer" %>
      </div>
    <% end %>

    <hr class="my-6 border-gray-200" />

    <div class="text-center">
      <p class="text-sm text-gray-500 mb-2">Want to leave?</p>
      <%= button_to "Cancel my account", registration_path(resource_name),
          data: { turbo_confirm: "Are you sure you want to delete your account?" },
          method: :delete,
          class: "text-sm text-red-600 hover:underline bg-transparent border-0 cursor-pointer" %>
    </div>
  </div>
</div>
