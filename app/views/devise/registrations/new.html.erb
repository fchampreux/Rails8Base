<% provide(:title, "Sign up") %>

<div class="flex items-center justify-center min-h-[60vh]">
  <div class="w-full max-w-md bg-white rounded-sm border-2 border-solid border-blue-400 p-8">
    <h2 class="text-xl font-semibold text-emerald-700 mb-6">Sign up</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-4">
        <%= f.label :code, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :code, autofocus: true, autocomplete: "username",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :first_name, autocomplete: "given-name",
              class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
        </div>
        <div>
          <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :last_name, autocomplete: "family-name",
              class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
        </div>
      </div>

      <div class="mb-4">
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autocomplete: "email",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <% if @minimum_password_length %>
          <p class="text-xs text-gray-400 mb-1"><%= @minimum_password_length %> characters minimum</p>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
      </div>

      <div class="mb-4">
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
      </div>

      <div class="mt-6">
        <%= f.submit "Sign up", class: "w-full bg-emerald-700 text-white py-2 px-4 rounded text-sm font-medium hover:bg-emerald-800 cursor-pointer" %>
      </div>
    <% end %>

    <hr class="my-6 border-gray-200" />
    <%= render "devise/shared/links" %>
  </div>
</div>
