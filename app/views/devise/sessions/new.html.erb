<% provide(:title, "Sign in") %>

<div class="flex items-center justify-center min-h-[60vh]">
  <div class="w-full max-w-md bg-white rounded-sm border-2 border-solid border-blue-400 p-8">
    <h2 class="text-xl font-semibold text-emerald-700 mb-2">Sign in</h2>
    <p class="text-sm text-gray-500 mb-6">
      Need an account?
      <%= mail_to $AdministratorEmail, "Contact us", subject: "Requesting access to #{$AppName}" %>
    </p>

    <% flash.each do |key, value| %>
      <p class="mb-4 text-sm text-red-600"><%= value %></p>
    <% end %>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :login, "Email or code", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :login, autofocus: true, autocomplete: "username",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center mb-4">
          <%= f.check_box :remember_me, class: "mr-2" %>
          <%= f.label :remember_me, class: "text-sm text-gray-600" %>
        </div>
      <% end %>

      <div class="mt-6">
        <%= f.submit "Sign in", class: "w-full bg-emerald-700 text-white py-2 px-4 rounded text-sm font-medium hover:bg-emerald-800 cursor-pointer" %>
      </div>
    <% end %>

    <hr class="my-6 border-gray-200" />

    <%= render "devise/shared/links" %>
  </div>
</div>
