<% provide(:title, "Unlock account") %>

<div class="flex items-center justify-center min-h-[60vh]">
  <div class="w-full max-w-md bg-white rounded-sm border-2 border-solid border-blue-400 p-8">
    <h2 class="text-xl font-semibold text-emerald-700 mb-2">Unlock account</h2>
    <p class="text-sm text-gray-500 mb-6">Enter your email and we'll send you unlock instructions.</p>

    <%= form_for(resource, as: resource_name, url: user_unlock_path, html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-4">
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
      </div>

      <div class="mt-6">
        <%= f.submit "Send unlock instructions",
            class: "w-full bg-emerald-700 text-white py-2 px-4 rounded text-sm font-medium hover:bg-emerald-800 cursor-pointer" %>
      </div>
    <% end %>

    <hr class="my-6 border-gray-200" />
    <%= render "devise/shared/links" %>
  </div>
</div>
