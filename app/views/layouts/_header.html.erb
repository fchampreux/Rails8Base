<header class="inline-grid grid-cols-8 gap-4 bg-emerald-700 text-white rounded-sm">
  <div class="flex items-center col-span-6 h-16 mx-auto px-4 border-2 border-solid rounded-sm border-blue-400">
    <div id="brand" class="shrink-0 mx-4">
      <%= image_tag($Logo, alt: "Organisation", class: "h-12 w-full") %>
    </div>
    <div id="environment" class="mx-4 px-4">
      <%= Rails.env.production? ? "" : "#{Rails.env.capitalize} " %>
    </div>      
    <div id="page-title" class="mx-4 px-4">
      Title of the page currently displayed: <%= yield(:page_heading || :title) %>
    </div>
  </div>
  <div class="flex items-center col-span-1 h-16 mx-auto px-4 border-2 border-solid rounded-sm border-blue-400">
    <nav id="portal-navigation" class="inline-grid grid-cols-6 gap-4 justify-self-end shrink-0">
      <span>1</span>
      <span>2</span>
      <span>3</span>
      <span>4</span>
      <span>5</span>
      <span>6</span>
    </nav>
  </div>
</header>